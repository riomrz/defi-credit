# IOTA Network
IOTA_NODE_URL=https://api.testnet.iota.cafe
IOTA_FAUCET_URL=https://faucet.testnet.iota.cafe/api/enqueue
IOTA_NETWORK=testnet

# Move Package (set after deploy)
MOVE_PACKAGE_ID=0x_REPLACE_AFTER_DEPLOY
POOL_ALPHA_OBJECT_ID=0x_REPLACE_AFTER_DEPLOY
POOL_BETA_OBJECT_ID=0x_REPLACE_AFTER_DEPLOY
POOL_GAMMA_OBJECT_ID=0x_REPLACE_AFTER_DEPLOY

# Backend
DATABASE_URL=postgresql://deficredit:deficredit@localhost:5432/deficredit
ISSUER_DID=did:iota:tst:0xYOUR_ISSUER_DID
ISSUER_PRIVATE_KEY_HEX=YOUR_HEX_PRIVATE_KEY
JWT_SECRET=replace_with_strong_secret_32_chars_min
NEXT_PUBLIC_IOTA_NETWORK=testnet

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_IOTA_NETWORK=testnet
